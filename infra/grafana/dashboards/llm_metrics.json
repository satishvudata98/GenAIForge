{
  "title": "GenAI Forge — AI Quality",
  "uid": "genai-forge-llm",
  "description": "LLM token volume, estimated cost, cache hit rate, and model usage breakdown.",
  "tags": ["genai-forge"],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "annotations": { "list": [] },
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "LLM Token Volume (tokens/s) by Model",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(llm_tokens_total[5m])) by (model, token_type)",
          "legendFormat": "{{model}} {{token_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Estimated LLM Cost (USD/hr)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(llm_estimated_cost_usd_total[5m])) by (model) * 3600",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "RAG Cache Hit Rate (%)",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "green", "value": 50 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "100 * sum(rate(rag_cache_hits_total[5m])) / (sum(rate(rag_cache_hits_total[5m])) + sum(rate(rag_cache_misses_total[5m])) + 0.001)",
          "legendFormat": "Hit Rate",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Total Cache Hits vs Misses",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "expr": "sum(rag_cache_hits_total) or vector(0)",
          "legendFormat": "Cache Hits",
          "refId": "A"
        },
        {
          "expr": "sum(rag_cache_misses_total) or vector(0)",
          "legendFormat": "Cache Misses",
          "refId": "B"
        }
      ]
    },
    {
      "id": 5,
      "type": "barchart",
      "title": "Total Tokens by Model",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "options": { "xField": "model" },
      "targets": [
        {
          "expr": "sum(llm_tokens_total) by (model)",
          "legendFormat": "{{model}}",
          "refId": "A",
          "instant": true
        }
      ]
    }
  ]
}
