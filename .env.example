GOOGLE_API_KEY=
XAI_API_KEY=
TAVILY_API_KEY=

LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_DISABLED=false

NEXT_PUBLIC_APP_NAME=GenAI Forge
NEXT_PUBLIC_API_BASE_URL=http://localhost:48080/v1

