APP_NAME=GenAI Forge API
ENVIRONMENT=local
DEBUG=false
HOST=0.0.0.0
PORT=8000
API_V1_PREFIX=/v1
ALLOWED_ORIGINS=["http://localhost:43010","http://127.0.0.1:43010","http://localhost:48080","http://127.0.0.1:48080"]

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=genai_forge
POSTGRES_DSN=postgresql+asyncpg://postgres:postgres@postgres:5432/genai_forge

REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=3072

OPENAI_API_KEY=
COHERE_API_KEY=
