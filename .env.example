APP_NAME=GenAI Forge API
ENVIRONMENT=local
DEBUG=false
HOST=0.0.0.0
PORT=8000
API_V1_PREFIX=/v1
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=genai_forge
POSTGRES_DSN=postgresql+asyncpg://postgres:postgres@postgres:5432/genai_forge

REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=3072

OPENAI_API_KEY=
COHERE_API_KEY=

LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_DISABLED=false

NEXT_PUBLIC_APP_NAME=GenAI Forge
NEXT_PUBLIC_API_BASE_URL=http://localhost/v1

NGINX_PORT=8080
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
JAEGER_PORT=16686
